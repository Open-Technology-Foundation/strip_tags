#!/bin/bash
set -euo pipefail

# Resolve script location
prg0=$(readlink -fn -- "$0")
prgdir=$(dirname "$prg0")
prg=$(basename "$prg0")

# Create venv if missing
if [[ ! -d "$prgdir/.venv" ]]; then
  echo "Setting up virtual environment..." >&2
  python3 -m venv "$prgdir/.venv"
  # shellcheck source=/dev/null
  source "$prgdir/.venv/bin/activate"
  pip install -q -r "$prgdir/requirements.txt"
else
  # shellcheck source=/dev/null
  source "$prgdir/.venv/bin/activate"
fi

# Execute Python script
exec "$prgdir/$prg.py" "$@"
